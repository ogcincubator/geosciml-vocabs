<https://www.opengis.net/def/geosciml/classifier/cgi/earth-resource-expression/exposed> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;

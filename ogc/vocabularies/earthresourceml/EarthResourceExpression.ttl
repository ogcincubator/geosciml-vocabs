<https://www.opengis.net/def/geosciml/classifier/cgi/earth-resource-expression> a skos:Collection ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;
    skos:definition "All the Concepts in this vocabulary"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/earth-resource-expression> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;
    skos:member <https://www.opengis.net/def/geosciml/classifier/cgi/earth-resource-expression/alteration-halo>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/earth-resource-expression/botanical-anomaly>,

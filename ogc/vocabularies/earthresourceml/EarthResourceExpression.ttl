        <https://www.opengis.net/def/geosciml/classifier/cgi/earth-resource-expression/geophysical-anomaly>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/earth-resource-expression/gossan> ;
    skos:prefLabel "Earth Resource Expression - All Concepts"@en ;
    schema:citation "The original vocabulary - all its concepts"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/earth-resource-expression/alteration-halo> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;
    skos:definition "The Earth resource, concealed or exposed, has an anomalous rock alteration halo."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/earth-resource-expression/alteration-halo> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;
    skos:notation "03.."^^<http://resource.geosciml.org/datatype/LocalHierarchyKey> ;
    skos:prefLabel "alteration halo"@en ;
    skos:topConceptOf <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;
    schema:citation "Australia/New Zealand Government Geoscience Information Committee (GGIC)"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/earth-resource-expression/botanical-anomaly> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;
    skos:altLabel "vegetation anomaly"@en ;
    skos:definition "The Earth resource, concealed or exposed, has an anomalous botanical signature (eg, particular plant growth or absence of plants)."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/earth-resource-expression/botanical-anomaly> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;
    skos:notation "06.."^^<http://resource.geosciml.org/datatype/LocalHierarchyKey> ;
    skos:prefLabel "botanical anomaly"@en ;
    skos:topConceptOf <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;
    schema:citation "Australia/New Zealand Government Geoscience Information Committee (GGIC)"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/earth-resource-expression/concealed> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;
    skos:definition "The Earth resource is not exposed at the Earth's surface."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/earth-resource-expression/concealed> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;
    skos:notation "02.."^^<http://resource.geosciml.org/datatype/LocalHierarchyKey> ;
    skos:prefLabel "concealed"@en ;
    skos:topConceptOf <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;
    schema:citation "Australia/New Zealand Government Geoscience Information Committee (GGIC)"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/earth-resource-expression/geochemical-anomaly> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/earth-resource-expression> ;
    skos:definition "The Earth resource, concealed or exposed, has an anomalous geochemical signature."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/earth-resource-expression/geochemical-anomaly> ;

    skos:notation "01"^^<http://resource.geosciml.org/datatype/LocalHierarchyKey> ;
    skos:prefLabel "surface"@en ;
    skos:topConceptOf <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/waste-storage> ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/waste-storage> a skos:ConceptScheme ;
    skos:changeNote "2014-03-19 Original SKOS implementation, SMR"@en,
        "2015-01-08 OLR Edits to fix typos and remove '201403' from rdf file name."@en,
        "2016-11-29 OLR Regenerate SKOS-RDF file as part of migration to new vocabulary server. No change to previous concepts definitions."@en,
        "2020-06-23 NJC Added properties to ensure vocab matched Geoscience Australia's vocab profile (http://linked.data.gov.au/def/ga-skos-profile). Just annotation properties, no new content. Agents (creator/publisher) now not text but RDF resource. Dates (create/modified) derived from editorial notes & existing date properties."@en,
        "2025-06-04 NJC Updates metadata to meet the VocPub 5.1 profile"@en ;
    skos:definition "This file contains the CGI Waste Storage vocabulary, as defined by the IUGS Commission for Geoscience Information (CGI) Geoscience Terminology Working Group. The vocabulary defines concepts for categorizing approaches to material waste storage associated with Earth Resource extraction. By extension, this vocabulary includes all concepts in this conceptScheme, as well as concepts in any previous versions of the scheme."@en ;
    skos:editorialNote "This file contains the 2016 SKOS-RDF version of the CGI Waste Storage vocabulary. Compilation and review in Google doc spreadsheet; adopted June 2013 at GTWG face to face in St. Petersburg, Russia; converted to MS Excel XML for SKOS generation using SKOS_for_GA_from_XLS_2016.03.xslt"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifierscheme/cgi/2016.01/waste-storage> ;
    skos:hasTopConcept <https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage/surface>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage/underground>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage/underwater> ;
    skos:prefLabel "Waste Storage"@en ;
    schema:citation "https://earthresourceml.org"^^xsd:anyURI,
        "The EarthResourceML standard"@en ;
    schema:creator <https://linked.data.gov.au/org/cgi-gtwg> ;
    schema:dateCreated "2016-11-29"^^xsd:date ;
    schema:dateModified "2025-06-04"^^xsd:date ;
    schema:keywords <https://gcmd.earthdata.nasa.gov/kms/concept/e9f67a66-e9fc-435c-b720-ae32a2c3d8f5> ;
    schema:publisher <https://linked.data.gov.au/org/cgi> ;
    schema:status <https://linked.data.gov.au/def/reg-statuses/stable> .


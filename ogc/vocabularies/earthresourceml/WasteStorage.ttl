    schema:citation "Australia GGIC"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage/surface> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/waste-storage> ;
    skos:definition "Mining waste storage at open-sky environment (ground level)"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/waste-storage/surface> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/waste-storage> ;

<https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage> a skos:Collection ;
    skos:definition "All the Concepts in this vocabulary"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/waste-storage> ;
    skos:member <https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage/covered>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage/surface>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage/underground>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage/underwater> ;
    skos:prefLabel "Waste Storage - All Concepts"@en ;
    schema:citation "The original vocabulary - all its concepts"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage/covered> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/waste-storage> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage/surface> ;
    skos:definition "Covered mining waste storage at ground level"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/waste-storage/covered> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/waste-storage> ;
    skos:notation "01.1"^^<http://resource.geosciml.org/datatype/LocalHierarchyKey> ;
    skos:prefLabel "covered"@en ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage/underground> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/waste-storage> ;
    skos:definition "Mining waste storage at underground environment"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/waste-storage/underground> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/waste-storage> ;

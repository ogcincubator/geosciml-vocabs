<https://www.opengis.net/def/geosciml/classifier/cgi/waste-storage/underwater> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/waste-storage> ;
    skos:definition "Mining waste deposited at sea or lake floor (e.g. sea bed mining)"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/waste-storage/underwater> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/waste-storage> ;
    skos:notation "03"^^<http://resource.geosciml.org/datatype/LocalHierarchyKey> ;

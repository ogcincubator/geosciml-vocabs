<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree> a skos:Collection ;
    skos:definition "All Concepts in this vocabulary" ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree> ;

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/consolidation_variable> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/consolidation_not_specified> ;
    skos:definition "Consolidation ranges from unconsolidated to indurated on scale of description"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/consolidation_variable> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:prefLabel "consolidation variable"@en ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/incipient_consolidation> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/unconsolidated> ;
    skos:definition "Shoveled with difficulty, relative density 0.4 - 0.7."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/incipient_consolidation> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:prefLabel "incipient consolidation"@en ;
    schema:citation "NADM SLTTs 2004 after Bowles 1986"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/moderately_indurated> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/indurated> ;
    skos:definition "Multiple blows with standard rock hammer (less than 1 kg) are required to break rock."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/moderately_indurated> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:prefLabel "moderately indurated"@en ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/slightly_indurated> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/indurated> ;
    skos:definition "Rock can be broken with single blow from standard rock hammer (less than 1 kg mass)."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/slightly_indurated> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:prefLabel "slightly indurated"@en ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/unconsolidated_loose> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/unconsolidated> ;
    skos:definition "Easily shoveled, can be indented with fingers, Relative density 0.2-0.4."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/unconsolidated_loose> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:prefLabel "unconsolidated loose"@en ;
    schema:citation "NADM SLTTs 2004 after Bowles 1985"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/unconsolidated_very_loose> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/unconsolidated> ;
    skos:definition "Easily indented with fingers, Relative density 0.0-0.2."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/unconsolidated_very_loose> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:prefLabel "unconsolidated very loose"@en ;
    schema:citation "NADM SLTTs 2004 after Bowles 1984"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/variable_induration> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/indurated> ;
    skos:definition "Material is lithified, but induration varies at scale of description."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/variable_induration> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:prefLabel "variable induration"@en ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/well_consolidated> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/consolidated> ;
    skos:definition "Requires pick to loosen for shoveling, relative density 0.7-0.9."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/well_consolidated> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:prefLabel "well consolidated"@en ;
    schema:citation "NADM SLTTs 2004 after Bowles 1986"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/well_indurated> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/indurated> ;
    skos:definition "Particles in the rock are strongly bound together such that rock surface can only be broken with great difficulty using standard rock hammer (less than 1 kg mass)."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/well_indurated> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:prefLabel "well indurated"@en ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/consolidated> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/consolidation_not_specified> ;
    skos:definition "Particulate constituents of a compound material adhere to each other strongly enough that the aggregate can be considered a solid material in its own right."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/consolidated> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:narrower <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/indurated>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/well_consolidated> ;
    skos:prefLabel "consolidated"@en ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/consolidation_not_specified> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:definition "In normative descriptions, indicates that consolidation state is not a determining factor in identification, it may have any value."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/consolidation_not_specified> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:narrower <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/consolidated>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/consolidation_variable>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/unconsolidated> ;
    skos:prefLabel "consolidation not specified"@en ;
    skos:topConceptOf <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/unconsolidated> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/consolidation_not_specified> ;
    skos:definition "Particulate constituents of a compound material do not adhere to each other strongly enough that the aggregate can be considered a solid in its own right."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/unconsolidated> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:narrower <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/incipient_consolidation>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/unconsolidated_loose>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/unconsolidated_very_loose> ;
    skos:prefLabel "unconsolidated"@en ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/indurated> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/consolidated> ;
    skos:definition "Requires blasting or heavy equipment to loosen, Relative density 0.9-1.0. Rings to blow of hammer."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/consolidationdegree/indurated> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:narrower <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/moderately_indurated>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/slightly_indurated>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/variable_induration>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/well_indurated> ;
    skos:prefLabel "indurated"@en ;
    schema:citation "NADM SLTTs 2004 after Bowles 1987"@en .

<https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/consolidationdegree> a skos:ConceptScheme ;
    skos:changeNote "2009-07-14. create rdf/skos from excel spreadsheet."@en,
        "2010-02-08. SMR Clean up namespace declarations so concept URI's follow CGI URN scheme; concepts have URN, are not document fragments."@en,
        "2010-02-12 Add narrower relationship links by adding skos:narrower link in Protege, defining skos:narrower as inverse of skos:broader, calculating with Pellet reasoner to add inferred axioms, and using 'file/Export inferred axioms as ontology' in Protege."@en,
        "2010-11-27 SMR. URIs mapped from CGI URNs in 200811 version to http URIs according to CGI URI scheme (https://www.seegrid.csiro.au/wiki/bin/view/CGIModel/PersistentIdentifiersInGeoSciMLServices#Example_Instances)"@en,
        "2011-07-07. GD - Clean up topConcept associations, remove the 'transitive' characteristic of the 'hasTopConcept' object property."@en,
        "2012-02-04 SMR Update to 201211 version; add collection entity, check all pref labels are lower case, remove owl:NamedIndividual and Owl:Thing rdf:types. Add missing for missing definitions."@en,
        "2012-02-07 SMR update URI to replace numeric final token with English-language string as in original URN scheme."@en,
        "2012-02-27 SMR add skos:exactMatch triples to map URIs for concepts in this vocabulary to number-token URIs in 201012 version of same concepts."@en,
        "2013-02-04 SMR Update to 201211 version; add collection entity, check all pref labels are lower case, remove owl:NamedIndividual and Owl:Thing rdf:types. Add missing for missing definitions."@en,
        "2016-06-15 OLR - redo Excel spreadsheet to work with XSLT, to make consistent SKOS-RDF with all CGI vocabularies. Generate new SKOS-RDF file."@en,
        "2020-06-23 NJC Added properties to ensure vocab matched Geoscience Australia's vocab profile (http://linked.data.gov.au/def/ga-skos-profile). Just annotation properties, no new content. Agents (creator/publisher) now not text but RDF resource. Dates (create/modified) derived from editorial notes & existing date properties."@en,
        "2025-06-04 NJC Updates metadata to meet the VocPub 5.1 profile"@en ;
    skos:definition "This scheme describes the concept space for Earth Material Consolidation Degree concepts, as defined by the IUGS Commission for Geoscience Information (CGI) Geoscience Terminology Working Group. By extension, it includes all concepts in this conceptScheme, as well as concepts in any previous versions of the scheme. Designed for populating the consolidationDegree property in GeoSciML RockMaterialDescription elements."@en ;
    skos:editorialNote "This file contains the 2016 SKOS-RDF version of the CGI Consolidation Degree vocabulary. Compilation and review in MS Excel spreadsheet, converted to MS Excel for SKOS generation using GSML_SKOS_fromXLS_2016.01.xslt."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifierscheme/cgi/2016.01/consolidationdegree> ;
    skos:hasTopConcept <https://www.opengis.net/def/geosciml/classifier/cgi/consolidationdegree/consolidation_not_specified> ;
    skos:prefLabel "Consolidation Degree"@en ;
    schema:citation "http://www.opengis.net/doc/geosciml/4.1"^^xsd:anyURI,
        "Original set of terms from the GeosciML standard" ;
    schema:creator <https://linked.data.gov.au/org/cgi-gtwg> ;
    schema:dateCreated "2009-07-14"^^xsd:date ;
    schema:dateModified "2025-06-04"^^xsd:date ;
    schema:keywords "GeoSciML" ;
    schema:publisher <https://linked.data.gov.au/org/cgi> ;
    schema:status <https://linked.data.gov.au/def/reg-statuses/stable> .


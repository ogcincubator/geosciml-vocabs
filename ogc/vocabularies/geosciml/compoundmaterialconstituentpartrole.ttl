    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/orthomatrix> ;
    skos:definition "Orthomatrix in matrix supported sedimentary rock."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/clast_supporting_orthomatrix> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "clast supporting orthomatrix"@en ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/clot> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/structural_part> ;
    skos:definition "A cluster of ferromagnesian minerals in an igneous rock,from several centimeters to decimeters in diameter,that may be a segregation or an altered xenolith."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/clot> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "clot"@en ;
    schema:citation "Neuendorf et al,2005"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/constituent_role_not_specified> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:definition "For descriptions in which role of constituent in compound material is not specified."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/constituent_role_not_specified> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "constituent role not specified"@en ;
    skos:topConceptOf <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/corrosion_rim> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/corona> ;
    skos:definition "A corona formed by a secondary mineral around an orginal igneous crystal,formed by modification of the crystal by the corrosive action of its parent magma"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/corrosion_rim> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "corrosion rim"@en ;
    schema:citation "Neuendorf et al.,2005"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/crystalline_framework_constituent> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/particulate_constituent> ;
    skos:definition "Constituent forms an interconnected network of discernible crystals."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/crystalline_framework_constituent> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "crystalline framework constituent"@en ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/dropstone> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/structural_part> ;
    skos:definition "An oversized stone in laminated sediment that depresses the underlying laminae and may be covered by -draped laminae. Most dropstones originate through ice-rafting, other sources are floating tree roots and kelp holdfasts..."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/dropstone> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "dropstone"@en ;
    schema:citation "NADM SLTTs 2004, Jackson,1997,p 193"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/epimatrix> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/matrix> ;
    skos:definition "A type of matrix consisting of inhomogeneous interstitial materials grown in originally open interstices during diagenesis,but lacking the homogeneity and clear textural evidence of pore-filling needed to classify as phyllosilicate cement."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/epimatrix> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "epimatrix"@en ;
    schema:citation "NADM SLTTs 2004, Dickinson,1970"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/floating_clast> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/structural_part> ;
    skos:definition "Constituent is a clast that has no visible contacts with other clasts. Interpreted to be largely or completly immersed in matrix or cement."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/floating_clast> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "floating clast"@en ;
    schema:citation "Pettijohn et al.,1972,p. 90, SMR"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/granular_framework_constituent> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/particulate_constituent> ;
    skos:definition "Constituent forms a rigid arrangement of particles that support one another at their points of contact...constituting a mechanically firm structure capable of supporting open pore spaces,although interstices may be occupied by cement or matrix"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/granular_framework_constituent> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "granular framework constituent"@en ;
    schema:citation "Jackson,1997,p. 250"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/groundmass_constituent> a skos:Concept ;

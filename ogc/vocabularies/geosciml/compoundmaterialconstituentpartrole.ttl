<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/particulate_constituent> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:definition "Constituent occurs as a collection of particles that are characterized by average properties of the individual particles"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/particulate_constituent> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:narrower <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/armoured_relict_crystal>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/chadacryst>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/crystalline_framework_constituent>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/granular_framework_constituent>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/megacryst>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/oikocryst>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/phenoclast> ;
    skos:prefLabel "particulate constituent"@en ;
    skos:topConceptOf <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/structural_part> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:definition "Constituent occurs in a structural configuration integral to the rock,such as layering,veinlets,overgrowths. The 'material' composition of these parts will often be other rock materials,not minerals,and 'ParticleGeometryDescription' associated with these describes the geometry of the constituent,not the particles the it is made of. These roles are mostly useful for RockMaterial descriptions that apply to individual samples,because their distribution is unlikely to be pervasive enought to be considered characteristic of a large mass of material."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/structural_part> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:narrower <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/clot>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/corona>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/dropstone>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/floating_clast>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/inclusion>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/irregular_part>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/layer>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/overgrowth>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/small_concretion>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/vein> ;
    skos:prefLabel "structural part"@en ;
    skos:topConceptOf <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    schema:citation "This vocabulary"@en .

<https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> a skos:ConceptScheme ;
    skos:changeNote "2009-07-14. create rdf/skos from excel spreadsheet."@en,
        "2009-12-07 SMR Update metadata properties for version, creator, title, and format. Change skos:HistoryNote to dc:source for information on origin of terms and definitions."@en,
        "2010-02-08 add top property assertions for root elements"@en,
        "2010-02-08. SMR Clean up namespace declarations so concept URI's follow CGI URN scheme; concepts have URN, are not document fragments."@en,
        "2010-02-12 Add narrower relationship links by adding skos:narrower link in Protege, defining skos:narrower as inverse of skos:broader, calculating with Pellet reasoner to add inferred axioms, and using 'file/Export inferred axioms as ontology' in Protege."@en,
        "2012-02-07 SMR update URI to replace numeric final token with English-language string as in original URN scheme."@en,
        "2012-11-24 SMR Update to 201211 version; add collection entity, check all pref labels are lower case, remove owl:NamedIndividual and Owl:Thing rdf:types."@en,
        "2016-06-15 OLR Update Excel spreadsheet format to work with new XSLT. Generated new SKOS-RDF to be consistent with all CGI vocabularies. No change to 201211 concepts."@en,
        "2020-06-23 NJC Added properties to ensure vocab matched Geoscience Australia's vocab profile (http://linked.data.gov.au/def/ga-skos-profile). Just annotation properties, no new content. Agents (creator/publisher) now not text but RDF resource. Dates (create/modified) derived from editorial notes & existing date properties."@en,
        "2021-12-17 R.Heaven BGS Added prefLabel and altLabel in non English languages, obtained from previously determined alignments between @en labels in CGI and Multi-lingual Thesaurus of Geosciences (MulTG) and Asian Multi-lingual Thesaurus of Geosciences (AMTG). Note that specific language packs are required to render the fonts.  Known issues: @lo and @fi labels were incorrectly encoded in the digitised source datasets; they have been included regardless of this in case the encoding can be corrected."@en,
        "2025-06-04 NJC Updates metadata to meet the VocPub 5.1 profile"@en ;
    skos:definition "This scheme describes the concept space for Compound Material Constituent Part concepts, as defined by the IUGS Commission for Geoscience Information (CGI) Geoscience Terminology Working Group. By extension, it includes all concepts in this conceptScheme, as well as concepts in any previous versions of the scheme. Used to categorize kinds of particles that are the constituents of a compound material. Designed for populating the ConstituentPart/role property in GeoSciML CompoundMaterialDescription elements."@en ;
    skos:editorialNote "This file contains the 2016 SKOS-RDF version of the CGI Compound Material Constituent Part vocabulary. Compilation and review in MS Excel spreadsheet, converted to MS Excel for SKOS generation using GSML_SKOS_fromXLS_2016.01.xslt."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:hasTopConcept <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/constituent_role_not_specified>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/interstitial_constituent>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/particulate_constituent>,
        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/structural_part> ;
    skos:prefLabel "Compound Material Constituent Part"@en ;
    schema:citation "http://www.opengis.net/doc/geosciml/4.1"^^xsd:anyURI,
        "Original set of terms from the GeosciML standard" ;

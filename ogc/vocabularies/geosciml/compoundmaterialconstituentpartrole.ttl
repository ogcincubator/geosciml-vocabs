<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/armoured_relict_crystal> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/particulate_constituent> ;
    skos:definition "A crystal of an earlier rock that is prevented from further reaction in a later rock by a rim of reaction products"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/armoured_relict_crystal> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "armoured relict crystal"@en ;
    schema:citation "base on Neuendorf et al 2005"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/armoured_relict_inclusion> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/inclusion> ;
    skos:definition "an inclusion of an earlier rock that is prevented from further reaction in a later rock by a rim of reaction products"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/armoured_relict_inclusion> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "armoured relict inclusion"@en ;
    schema:citation "base on Neuendorf et al 2005"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/chadacryst> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/particulate_constituent> ;
    skos:definition "The enclosed crystal in a poikolitic texture"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/chadacryst> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "chadacryst"@en ;
    schema:citation "Neuendorf et al.,2005"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/clast_supporting_orthomatrix> a skos:Concept ;

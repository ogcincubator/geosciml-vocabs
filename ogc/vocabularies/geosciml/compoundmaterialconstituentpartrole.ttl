        <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/porphyroclast> ;
    skos:prefLabel "megacryst"@en ;
    schema:citation "Neuendorf et al 2005"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/matrix> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:altLabel "zat dasar"@id ;

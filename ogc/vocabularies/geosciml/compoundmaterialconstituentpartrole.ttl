    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/megacryst> ;
    skos:definition "Relict crystal in metamorphic rock,in groundmass of relatively finer-grained material. Connotes that groundmass is result of tectonic reduction in grain size."@en ;

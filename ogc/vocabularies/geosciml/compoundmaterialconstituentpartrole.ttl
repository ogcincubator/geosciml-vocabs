<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/pseudomatrix> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/matrix> ;
    skos:definition "A type of matrix consisting of soft deformable framework grains that are squeezed and flattened between stronger framework grains."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/pseudomatrix> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "pseudomatrix"@en ;
    schema:citation "NADM SLTTs 2004, Dickinson,1970"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/sedimentary_rock_cement> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/interstitial_constituent> ;
    skos:definition "A constituent that occupies space between individual grains of a consolidated sedimentary rock,and binds the grains together as a rigid,coherent mass, it may be derived from the sediment or its entrapped waters,or it may be brought in by solution from outside sources. Material is usually chemically precipitated (Jackson,1997,p. 103). Distinguished from matrix by clearly secondary origin and generally monomineralic character."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/sedimentary_rock_cement> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "sedimentary rock cement"@en ;
    schema:citation "NADM SLTTs 2004, Jackson,1997"@en .

<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/small_concretion> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/structural_part> ;
    skos:definition "A hard,compact mass or aggregate of mineral matter,normally subsperical but commonly oblate,disc-shaped or irregular. Formed by precipitation of mineral from solution in the pores of a granular rock,localized around a nucleus or center,to define a discrete,sharply separated object. Size ranges from cm to decimeter for application as a compoundMaterialConstituentPart, larger concretions should be considered GeologicUnit parts."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/small_concretion> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:prefLabel "small concretion"@en ;
    schema:citation "Neuendorf et al,2005"@en .


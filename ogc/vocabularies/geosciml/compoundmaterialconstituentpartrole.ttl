<https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/megacryst> a skos:Concept ;
    rdfs:isDefinedBy <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;
    skos:broader <https://www.opengis.net/def/geosciml/classifier/cgi/compoundmaterialconstituentpartrole/particulate_constituent> ;
    skos:definition "Any crystal in an igneous or metamorphic rock that is sgnificantly larger than the surounding groundmass. May be a phenocryst,xenocryst,porphyroblast or porphyroclast"@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/megacryst> ;
    skos:inScheme <https://www.opengis.net/def/geosciml/classifierscheme/cgi/2016.01/compoundmaterialconstituentpartrole> ;

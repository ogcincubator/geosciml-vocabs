    skos:definition "Constituent occurs as a concentric envelope enclosing another constituent. Corona is a non-genetic term."@en ;
    skos:exactMatch <http://resource.geosciml.org/classifier/cgi/compoundmaterialconstituentpartrole/corona> ;
